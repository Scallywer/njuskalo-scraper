# Copy to .env (gitignored) and fill in. The nightly job sources .env.
#
# Telegram push notifications for the watchlist:
#   1. In Telegram, message @BotFather -> /newbot -> follow prompts -> copy the token.
#   2. Send any message to your new bot.
#   3. Put the token below, then run:  python -m electronics.notify --get-chat-id
#      to get your chat id; put it below too.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: a paid rotating proxy endpoint (one URL). If set, all crawling routes
# through it. Leave blank to crawl direct.
# NJ_PROXY_ENDPOINT=http://user:pass@gateway.example.com:7000
